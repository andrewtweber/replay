{
    "name": "andrewtweber/replay",
    "description": "Track changes to Laravel Eloquent models as replayable steps, and replay them to reproduce any state.",
    "keywords": ["laravel", "eloquent", "audit", "replay", "history", "versioning"],
    "license": "MIT",
    "authors": [
        {
            "name": "Andrew Weber"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.11|^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Replay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Replay\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Replay\\ReplayServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
